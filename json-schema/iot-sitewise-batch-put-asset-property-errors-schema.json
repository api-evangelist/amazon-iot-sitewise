{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/api-evangelist/amazon-iot-sitewise/refs/heads/main/json-schema/iot-sitewise-batch-put-asset-property-errors-schema.json",
  "title": "BatchPutAssetPropertyErrors",
  "description": "BatchPutAssetPropertyErrors schema",
  "type": "array",
  "items": {
    "type": "object",
    "required": [
      "errorCode",
      "errorMessage",
      "timestamps"
    ],
    "properties": {
      "errorCode": {
        "allOf": [
          {
            "$ref": "#/components/schemas/BatchPutAssetPropertyValueErrorCode"
          },
          {
            "description": "The error code."
          }
        ]
      },
      "errorMessage": {
        "allOf": [
          {
            "$ref": "#/components/schemas/ErrorMessage"
          },
          {
            "description": "The associated error message."
          }
        ]
      },
      "timestamps": {
        "allOf": [
          {
            "$ref": "#/components/schemas/Timestamps"
          },
          {
            "description": "A list of timestamps for each error, if any."
